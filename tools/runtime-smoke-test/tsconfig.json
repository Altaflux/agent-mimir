{
  "compilerOptions": {
    "target": "ES2021",
    "allowSyntheticDefaultImports": true,
    "baseUrl": "src",
    "declaration": true,
    "sourceMap": true,
    "inlineSourceMap": false,
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "module": "NodeNext",
    "outDir": "dist",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
